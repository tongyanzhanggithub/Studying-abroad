    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && next build",
    "db:start": "tsx scripts/db-local.ts",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "data:import": "tsx scripts/import-programs.ts",
    "admin:create": "tsx scripts/create-admin.ts",
    "demo:seed": "tsx --tsconfig scripts/tsconfig.json scripts/seed-demo-user.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "@tiptap/extension-character-count": "^2.11.2",
