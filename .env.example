# ── 数据库 ────────────────────────────────────────────────
# 端口用 5433/6380 避开本机可能已占用的默认端口
DATABASE_URL="postgresql://compass:compass_dev_pwd@localhost:5433/compass?schema=public"
REDIS_URL="redis://localhost:6380"

# ── 会话 ──────────────────────────────────────────────────
# 生产环境必须替换:openssl rand -base64 32
AUTH_SECRET="dev-only-secret-change-me-in-production-please"

# 定时任务接口密钥。会明文写进 /etc/cron.d/compass,所以和 AUTH_SECRET 分开。
# 不填就退回用 AUTH_SECRET。生产建议单独生成一个:openssl rand -base64 32
CRON_SECRET=""

# ── LLM 网关 ──────────────────────────────────────────────
# 供应商: anthropic | openai_compatible | mock
# PRD 10.4 要求境内合规模型;openai_compatible 可接通义/DeepSeek/豆包/Kimi 等
LLM_PROVIDER="mock"

# provider = anthropic
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-5"

# provider = openai_compatible(填你的服务商 base_url)
# 通义千问: https://dashscope.aliyuncs.com/compatible-mode/v1
# DeepSeek:  https://api.deepseek.com/v1
# 月之暗面:  https://api.moonshot.cn/v1
OPENAI_COMPAT_BASE_URL=""
OPENAI_COMPAT_API_KEY=""
OPENAI_COMPAT_MODEL=""

# ── 支付 ──────────────────────────────────────────────────
# mock | wechat  —— 微信支付商户号下来前保持 mock
PAYMENT_PROVIDER="mock"
WECHAT_MCH_ID=""
WECHAT_APP_ID=""
WECHAT_API_V3_KEY=""
WECHAT_CERT_SERIAL=""
WECHAT_PRIVATE_KEY_PATH=""
WECHAT_NOTIFY_URL=""

# ── 短信(截止日强提醒 / 登录验证码)────────────────────────
# mock 时验证码直接打印在服务端日志,不真实下发
SMS_PROVIDER="mock"

# 演示环境逃生门:生产环境没接短信时,允许靠「读服务端日志」登录。
#   不设(默认):生产 + mock 短信 = 登录直接报错(安全默认值)
#   设为 true:验证码只写进服务端日志,**不会返回给页面** ——
#             所以只有能 SSH 看日志的人能登,公网上的人拿不到别人的码。
# ⚠️ 接入真实短信后必须删掉这一行。
ALLOW_MOCK_SMS=""
SMS_ACCESS_KEY=""
SMS_ACCESS_SECRET=""
SMS_SIGN_NAME=""

# ── 对象存储(材料上传)────────────────────────────────────
# local | oss
#   local: 存 ./uploads,已做 AES-256-GCM 落盘加密,可用于开发/临时环境
#   oss:   阿里云 OSS。切之前先 `npm i ali-oss`,并在控制台把桶设为私有 + 开服务端加密
#          (见 deploy/云上安全.md P0-4)。key 用 RAM 子账号,只授这一个桶的读写。
STORAGE_PROVIDER="local"
OSS_REGION=""
OSS_BUCKET=""
OSS_ACCESS_KEY_ID=""
OSS_ACCESS_KEY_SECRET=""
# ECS 与 OSS 同区域时置 true,走内网 endpoint(免公网流量费、更安全)
OSS_INTERNAL="false"

# ── 站点 ──────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
